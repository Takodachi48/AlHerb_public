# Shared secrets/overrides for ML services

INTERNAL_API_KEY=replace-with-at-least-32-random-characters

# recommendation-engine + image-classifier target for Express persistence endpoints
RECOMMENDATION_ENGINE_PORT=8001
# Local dev: http://localhost:5000
# Hugging Face/Vercel example: https://<your-server-domain>
MAIN_API_URL=http://localhost:5000
# Local dev: false | Hugging Face/Vercel cross-service calls: true
ALLOW_EXTERNAL_INTERNAL_CALLS=false
