RECOMMENDATION_ENGINE_PORT=8001
RECOMMENDATION_RETRAIN_THRESHOLD=500
RECOMMENDATION_CHECK_INTERVAL_HOURS=6
RECOMMENDATION_RETRAIN_BUFFER_MINUTES=60
IMAGE_CLASSIFIER_RETRAIN_CRON=0 2 * * *

# Local dev: http://localhost:5000
# Hugging Face Space example: https://<your-server-space>.hf.space
# Vercel example: https://<your-server-project>.vercel.app
MAIN_API_URL=http://localhost:5000
INTERNAL_API_KEY=replace-with-at-least-32-random-characters
# Local dev: false | Hugging Face/Vercel cross-service calls: true
ALLOW_EXTERNAL_INTERNAL_CALLS=false
