# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Internal API (Express server) for persistence
# Local dev: http://localhost:5000
# Hugging Face Space example: https://<your-server-space>.hf.space
# Vercel example: https://<your-server-project>.vercel.app
MAIN_API_URL=http://localhost:5000
INTERNAL_API_KEY=replace-with-at-least-32-random-characters
# Local dev: false | Hugging Face/Vercel cross-service calls: true
ALLOW_EXTERNAL_INTERNAL_CALLS=false

# Redis Configuration
# Local machine:
REDIS_URL=redis://127.0.0.1:6379/0
# Docker compose service-name example:
# REDIS_URL=redis://redis:6379/0

# Model Settings
STUDENT_MODEL=mobilenetv3_small_100
TEACHER_MODEL=efficientnet_b0
# Must match your trained label space (e.g. 3, 10, 40).
NUM_CLASSES=3
INFERENCE_TEMPERATURE=2.0
# Optional overrides when needed:
# STUDENT_PATH=src/models/student/best_student_model.pth
# IMPORTANT:
# TEACHER_PATH must point to a real teacher checkpoint (EfficientNet teacher weights),
# not a renamed student checkpoint. Supported keys inside checkpoint include:
#   teacher_model_state_dict, model_state_dict, state_dict, or raw state_dict.
# If TEACHER_PATH is missing/invalid, retraining will be unavailable.
# TEACHER_PATH=src/models/teacher/best_teacher_model.pth
# ACTIVE_MODEL_PATH=src/models/active/model.pth
