# Firebase Web configuration (used by Firebase JS SDK in Expo)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth client IDs
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# API configuration
EXPO_PUBLIC_API_BASE_URL=https://your-public-api-tunnel.example

# Optional comma-separated fallback API base URLs.
# Example: https://api-primary.example,https://api-backup.example
EXPO_PUBLIC_API_FALLBACK_URLS=

# Optional: enable verbose debug logging in development.
# Set true only when actively debugging.
EXPO_PUBLIC_DEBUG_LOGS=false

# Turnstile site key for native captcha challenge (optional).
# Required only when backend Turnstile is enabled.
EXPO_PUBLIC_TURNSTILE_SITE_KEY=
