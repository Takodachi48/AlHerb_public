# Firebase Configuration
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=GA-XXXXXXXXX

# Google Identity Services (One Tap / account chooser)
VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# API Configuration
VITE_API_BASE_URL=/api
# Local Server API URL (if using Vite proxy for local development)  
# VITE_API_PROXY_TARGET=http://localhost:5000
# Deployed Server API URL (if not using local proxy)
VITE_API_PROXY_TARGET=http://<your-server-domain>
# Increase when proxying to sleeping/slow remote backends (e.g. HF Space cold starts)
VITE_API_PROXY_TIMEOUT_MS=120000

# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=your-cloudinary-name

# Cloudflare Turnstile
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
